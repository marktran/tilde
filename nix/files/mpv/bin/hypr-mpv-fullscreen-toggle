#!/bin/bash
set -euo pipefail

# Toggle fullscreen for mpv windows in a Hyprland PiP setup.
# - Entering fullscreen: save geometry, unpin + unfloat, then fullscreen.
# - Leaving fullscreen: exit fullscreen, restore float + pin + saved geometry.

STATE_DIR="${XDG_RUNTIME_DIR:-/tmp}/hypr-mpv-fullscreen"
mkdir -p "$STATE_DIR"

active="$(hyprctl activewindow -j 2>/dev/null || true)"
[[ -z "${active}" ]] && exit 0

class="$(echo "$active" | jq -r '.class // .initialClass // ""')"
fullscreen="$(echo "$active" | jq -r '.fullscreen // 0')"
pinned="$(echo "$active" | jq -r '.pinned // false')"
floating="$(echo "$active" | jq -r '.floating // false')"
address="$(echo "$active" | jq -r '.address // ""')"

# Fallback for non-mpv windows: just toggle fullscreen.
if [[ ! "$class" =~ ^mpv$ ]]; then
  hyprctl dispatch fullscreen 0 >/dev/null 2>&1 || true
  exit 0
fi

is_fullscreen=0
if [[ "$fullscreen" == "1" || "$fullscreen" == "2" || "$fullscreen" == "true" ]]; then
  is_fullscreen=1
fi

state_file="${STATE_DIR}/${address}"

if [[ "$is_fullscreen" -eq 1 ]]; then
  hyprctl dispatch fullscreen 0 >/dev/null 2>&1 || true

  # Restore PiP behavior when leaving fullscreen.
  if [[ "$floating" != "true" ]]; then
    hyprctl dispatch togglefloating >/dev/null 2>&1 || true
  fi
  if [[ "$pinned" != "true" ]]; then
    hyprctl dispatch pin >/dev/null 2>&1 || true
  fi

  # Restore saved position/size, or center as fallback.
  if [[ -f "$state_file" ]]; then
    IFS=' ' read -r sx sy sw sh < "$state_file"
    hyprctl dispatch movewindowpixel "exact $sx $sy,address:$address" >/dev/null 2>&1 || true
    hyprctl dispatch resizewindowpixel "exact $sw $sh,address:$address" >/dev/null 2>&1 || true
    rm -f "$state_file"
  else
    hyprctl dispatch centerwindow >/dev/null 2>&1 || true
  fi
else
  # Save current geometry before going fullscreen.
  x="$(echo "$active" | jq -r '.at[0] // 0')"
  y="$(echo "$active" | jq -r '.at[1] // 0')"
  w="$(echo "$active" | jq -r '.size[0] // 0')"
  h="$(echo "$active" | jq -r '.size[1] // 0')"
  echo "$x $y $w $h" > "$state_file"

  # Ensure the window can actually fullscreen.
  if [[ "$pinned" == "true" ]]; then
    hyprctl dispatch pin >/dev/null 2>&1 || true
  fi
  if [[ "$floating" == "true" ]]; then
    hyprctl dispatch togglefloating >/dev/null 2>&1 || true
  fi

  hyprctl dispatch fullscreen 0 >/dev/null 2>&1 || true
fi
