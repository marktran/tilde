#!/bin/bash
set -euo pipefail

# Re-apply the monitor rules from monitors.conf after suspend/DPMS wake.
#
# Workaround for Hyprland failing to replay wl_surface.enter events when
# outputs come back, which leaves GTK3 apps (Emacs PGTK, Firefox, ...)
# with a stale GDK buffer scale -> blurry windows on scaled displays.
# Re-applying the monitor rules forces Hyprland to re-announce the
# outputs so GDK recomputes the scale.
#
# See https://github.com/hyprwm/Hyprland/issues/6560 (fixed 2024-10,
# later regressed) and
# https://github.com/hyprwm/Hyprland/discussions/12439.
# Companion Emacs-side hack: emacs.d/lisp/hacks/wayland-resume-hack.el.
#
# Status 2026-07-19: fixed upstream.  Root cause was aquamarine
# calling impl->reset() (full CRTC deactivation) in restoreAfterVT()
# on every resume; removed in aquamarine d83c97f (v0.11.0, installed
# 2026-05-09).  Verified unreproducible on Hyprland 0.55.2/aq 0.12.0,
# incl. a raw 8 h overnight suspend and a synthetic morning-wake repro
# with all workarounds disabled.  Kept as cheap insurance:
# with unchanged rules Hyprland short-circuits before applyMonitorRule
# and only re-sends xdg_output state + wl_output.done, which nudges
# GDK to recompute window scales.  See the elisp file for the full
# investigation notes.

conf="${XDG_CONFIG_HOME:-$HOME/.config}/hypr/monitors.conf"

# Give slow panels a moment to finish waking before re-announcing.
sleep "${HYPR_REAPPLY_MONITORS_DELAY:-1}"

grep -E '^[[:space:]]*monitor[[:space:]]*=' "$conf" |
  sed -E 's/^[[:space:]]*monitor[[:space:]]*=[[:space:]]*//' |
  while IFS= read -r rule; do
    hyprctl keyword monitor "$rule" >/dev/null
  done
