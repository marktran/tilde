# dirs
method.insert = cfg.basedir,  private|const|string, (cat, (system.env, HOME), "/.local/share/rtorrent/")
method.insert = cfg.download, private|const|string, (cat, (system.env, HOME), "/Downloads/torrents/")
method.insert = cfg.complete, private|const|string, (cat, (system.env, HOME), "/Downloads/torrents/")
method.insert = cfg.watch,    private|const|string, (cat, (system.env, HOME), "/Downloads/")
method.insert = cfg.session,  private|const|string, (cat, (cfg.basedir), "session/")
method.insert = cfg.logs,     private|const|string, (cat, (cfg.basedir), "log/")

execute.throw = mkdir, -p, (cat, (cfg.download))
execute.throw = mkdir, -p, (cat, (cfg.complete))
execute.throw = mkdir, -p, (cat, (cfg.session))
execute.throw = mkdir, -p, (cat, (cfg.logs))

directory.default.set = (cat, (cfg.download))
session.path.set      = (cat, (cfg.session))

# network
network.port_range.set  = 50000-50000
network.port_random.set = no

throttle.max_uploads.set             = 100
throttle.max_uploads.global.set      = 250
throttle.max_downloads.global.set    = 250
throttle.global_down.max_rate.set_kb = 0
throttle.global_up.max_rate.set_kb   = 500

dht.mode.set         = auto
dht.override_port.set = 6881
protocol.pex.set     = yes
trackers.use_udp.set = yes

# peers
throttle.min_peers.normal.set = 20
throttle.max_peers.normal.set = 100
throttle.min_peers.seed.set   = 30
throttle.max_peers.seed.set   = 80

network.max_open_files.set      = 600
network.max_open_sockets.set    = 300
network.http.max_open.set       = 50
network.send_buffer.size.set    = 4M
network.receive_buffer.size.set = 4M

protocol.encryption.set = allow_incoming,try_outgoing,enable_retry

# pieces
pieces.hash.on_completion.set = yes
pieces.memory.max.set         = 2048M
system.file.allocate.set      = yes

# watch
schedule2 = watch_directory, 5, 5, ((load.start, (cat, (cfg.watch), "*.torrent"), "d.custom1.set=(cat,(cfg.watch))", "d.delete_tied="))

# complete
method.insert = d.move_to_complete, simple, \
    "d.directory.set=$d.custom1= ; \
     execute=mkdir,-p,$d.custom1= ; \
     execute=mv,-u,$d.base_path=,$d.custom1="

method.set_key = event.download.finished, move_complete, \
    "d.custom1.set=(cat,(cfg.complete)) ; d.move_to_complete="

# seeding
# stop seeding at ratio 1.00
group.seeding.ratio.enable =
group.seeding.ratio.min.set    = 100
group.seeding.ratio.max.set    = 100
group.seeding.ratio.upload.set = 0

# housekeeping
schedule2 = low_diskspace, 5, 60, ((close_low_diskspace, 2048M))

# logs
log.open_file  = "log", (cat, (cfg.logs), "rtorrent.log")
log.add_output = "info", "log"
